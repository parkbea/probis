@echo off
chcp 65001 >nul
echo ============================================
echo   Git Pull - probis 소스 내려받기
echo ============================================
echo.

cd /d "%~dp0"

echo [1/2] 원격 저장소에서 변경사항 확인 중...
git fetch origin

echo.
echo [2/2] main 브랜치 최신 소스 내려받는 중...
git pull origin main

echo.
if %ERRORLEVEL% == 0 (
    echo ============================================
    echo   완료! 최신 소스로 업데이트되었습니다.
    echo ============================================
) else (
    echo ============================================
    echo   오류가 발생했습니다. 위 메시지를 확인하세요.
    echo ============================================
)

echo.
pause
